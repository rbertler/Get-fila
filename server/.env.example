DATABASE_URL="postgresql://postgres:password@localhost:5432/fila"
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"
PORT=3001
CLIENT_URL="http://localhost:5173"
UPLOAD_DIR="./uploads"

# Anthropic — required for AI-powered record extraction
ANTHROPIC_API_KEY=""

# Supabase Storage (required in production — Render's disk is ephemeral).
# When unset, files are stored on local disk in UPLOAD_DIR instead.
# Find these in Supabase dashboard → Project Settings → API.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Google OAuth (optional — app works without these)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/google/callback"
